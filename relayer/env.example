# Relayer secret key (Stellar secret seed — must have XLM for fees)
RELAYER_SECRET=S...

# Factory contract address — used to whitelist pools automatically
FACTORY_ADDRESS=C...

# testnet | public
NETWORK=testnet

# Soroban RPC endpoint
RPC_URL=https://soroban-testnet.stellar.org

# Min fee-bump the relayer pays (stroops). Soroban pool ops often need ~600k+; actual fee = max(MAX_FEE, inner tx fee).
MAX_FEE=100000

# HTTP port
PORT=3002

# CORS origin for the frontend (e.g. https://sanca.app). Use * for open (testnet only).
CORS_ORIGIN=*

# How often to refresh the pool list from factory (ms). New pools are picked up automatically.
POOL_CACHE_REFRESH_MS=60000

# POST /sponsor — auto-create accounts for new Privy wallets (testnet uses Friendbot).
SPONSOR_ENABLED=true
# Mainnet only — XLM for createAccount (covers base reserve + headroom).
SPONSOR_STARTING_BALANCE=2

USDC_ASSET_CODE=USDC

# Blend USDC — Sanca pools + DeFindex (testnet SAC CAQCFVLO...)
BLEND_USDC_ISSUER=GATALTGTWIOT6BUDBCZM3Q4OQ4BO2COLOAZ7IYSKPLC2PMSOPPGF5V56

# Circle USDC — MoneyGram on/off ramp only
MONEYGRAM_USDC_ISSUER=GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5

# Max Circle USDC per relayed payment (MoneyGram off-ramp withdraw)
MAX_USDC_PAYMENT=3000
