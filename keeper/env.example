# Sanca factory contract (keeper discovers all pools via get_all_pools)
FACTORY_ADDRESS=

# Keeper secret key (Stellar secret seed) — signs settle_cycle on all pools
KEEPER_SECRET=

# Factory admin secret — only needed once for `npm run set-keeper`
ADMIN_SECRET=

# testnet | public
NETWORK=testnet

# Soroban RPC endpoint
RPC_URL=https://soroban-testnet.stellar.org

# Horizon fallback when Soroban RPC getTransaction fails (keeper polling)
HORIZON_URL=https://horizon-testnet.stellar.org

# Drand quicknet chain hash
DRAND_CHAIN_HASH=52db9ba70e0cc0f6eaf7803dd07447a1f5477735fd3f661792ba94600c84e971

# How often to poll factory + pool state (ms)
POLL_INTERVAL_MS=15000
